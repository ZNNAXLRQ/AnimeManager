<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.animemanager.Controller.MainController"
            stylesheets="@../CSS/main.css"
            styleClass="main-background">

    <left>
        <VBox spacing="20" styleClass="sidebar" prefWidth="240">
            <padding><Insets top="30" right="20" bottom="30" left="20"/></padding>
            <Label text="Anime Manager" styleClass="sidebar-title" wrapText="true"/>

            <Button onAction="#onUpdateDataClick" styleClass="sidebar-button" maxWidth="Infinity">
                <graphic>
                    <FontIcon iconLiteral="fas-sync-alt" iconSize="16" iconColor="white"/>
                </graphic>
                <text>   更新数据</text>
            </Button>

            <VBox spacing="10">
                <Label text="排序方式" styleClass="sidebar-subtitle"/>
                <ComboBox fx:id="sortCombo" maxWidth="Infinity" styleClass="sort-combo"/>
                <ToggleButton fx:id="ascDescToggle" text="顺序 (ASC)" maxWidth="Infinity" styleClass="sort-toggle"/>
            </VBox>

            <!-- 高级筛选区 -->
            <VBox spacing="10">
                <Label text="高级筛选" styleClass="sidebar-subtitle"/>
                <ComboBox fx:id="filterTypeCombo" maxWidth="Infinity" styleClass="sort-combo"/>
                <TextField fx:id="filterInput" promptText="输入过滤关键词..." styleClass="filter-field"/>
                <HBox spacing="10">
                    <Button text="类型筛选" onAction="#onFilterClick" styleClass="action-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="清空类型" onAction="#onClearFilterClick" styleClass="clear-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>
            </VBox>

            <!-- 日期筛选区域 -->
            <VBox spacing="10">
                <Label text="日期筛选" styleClass="sidebar-subtitle"/>
                <VBox spacing="10">
                    <TextField fx:id="startDateField" promptText="起始日期" styleClass="filter-field" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="endDateField" promptText="结束日期" styleClass="filter-field" HBox.hgrow="ALWAYS"/>
                </VBox>
                <HBox spacing="10">
                    <Button text="深度筛选" onAction="#onDateFilterClick" styleClass="action-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="清空日期" onAction="#onClearDateClick" styleClass="clear-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>
            </VBox>

            <!-- 加权均分统计区域 -->
            <VBox spacing="10">
                <Label text="加权均值统计" styleClass="sidebar-subtitle"/>
                <HBox spacing="10" styleClass="level-container">
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Bgm加权" styleClass="level-title"/>
                        <Label fx:id="bangumiLevelLabel" text="--" styleClass="level-value"/>
                    </VBox>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="本地加权" styleClass="level-title"/>
                        <Label fx:id="localLevelLabel" text="--" styleClass="level-value"/>
                    </VBox>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="均值偏移" styleClass="level-title"/>
                        <Label fx:id="Distancelabel" text="--" styleClass="level-value"/>
                    </VBox>
                </HBox>
                <Button text="计算均分" onAction="#calculateLevels" styleClass="action-button" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="10">
            <padding><Insets top="20" right="30" bottom="20" left="30"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="我的番剧库" styleClass="title-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchField" promptText="搜索番剧..." styleClass="search-field"/>
                <Label fx:id="statusLabel" text="就绪" styleClass="status-label" onMouseClicked="#toggleLogDrawer"/>
            </HBox>

            <!-- 后台日志抽屉 -->
            <VBox fx:id="logDrawer" styleClass="log-drawer" managed="false" visible="false" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Label text="控制台输出" styleClass="log-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="清空" onAction="#clearLog" styleClass="clear-button"/>
                    <Button text="关闭" onAction="#closeLogDrawer" styleClass="clear-button"/>
                </HBox>
                <ListView fx:id="logListView" VBox.vgrow="ALWAYS" styleClass="log-list"/>
            </VBox>

            <ListView fx:id="subjectListView" VBox.vgrow="ALWAYS" styleClass="subject-list"/>
        </VBox>
    </center>
</BorderPane>